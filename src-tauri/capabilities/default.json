{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granting core APIs, store, and opener to the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://arxiv.org/*" },
        { "url": "https://*.arxiv.org/*" },
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    }
  ]
}
