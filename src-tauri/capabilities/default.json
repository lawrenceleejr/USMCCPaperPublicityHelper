{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granting core APIs and app commands to the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default"
  ]
}
